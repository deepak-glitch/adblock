# Stream AdBlock Configuration
# Copy this to .env and edit as needed
# All values shown are the defaults

# ── DNS Server ────────────────────────────────────────────────────────
# Port to listen on for DNS queries
# Use 53 in production (requires root / NET_BIND_SERVICE)
# Use 5353 for local development without root
DNS_PORT=53

# IP address to bind the DNS server to (0.0.0.0 = all interfaces)
DNS_BIND=0.0.0.0

# Upstream DNS server (queries not in blocklist are forwarded here)
DNS_UPSTREAM=8.8.8.8
DNS_UPSTREAM_FALLBACK=8.8.4.4
DNS_UPSTREAM_PORT=53

# How to respond to blocked domains:
#   nxdomain  - Return RCODE 3 (domain doesn't exist) — recommended
#   null_ip   - Return 0.0.0.0 A record (prevents some TCP retries)
DNS_BLOCK_MODE=nxdomain

# Upstream query timeout in milliseconds
DNS_TIMEOUT_MS=3000

# In-memory DNS response cache size (number of entries)
DNS_CACHE_SIZE=10000

# ── Web Dashboard ─────────────────────────────────────────────────────
# Dashboard port
WEB_PORT=3000

# Dashboard bind address
WEB_BIND=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────
# SQLite database file path
DB_PATH=./data/adblock.db

# How many days of query history to keep
DB_RETENTION_DAYS=30

# Batch insert settings (for performance)
DB_BATCH_SIZE=200
DB_BATCH_MS=2000

# ── Blocklist Updates ─────────────────────────────────────────────────
# Cron schedule for automatic remote blocklist updates (default: 3 AM daily)
BLOCKLIST_UPDATE_CRON=0 3 * * *

# Set to 'false' to disable remote blocklist downloads
BLOCKLIST_REMOTE=true

# ── Logging ───────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info
